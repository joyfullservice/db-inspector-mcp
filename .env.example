# Database Backend Configuration
# Set to 'sqlserver' or 'postgres'
DB_BACKEND=sqlserver

# Database Connection String
# SQL Server example:
# DB_CONNECTION_STRING=Driver={ODBC Driver 17 for SQL Server};Server=localhost;Database=mydb;UID=user;PWD=password
# Or using DSN:
# DB_CONNECTION_STRING=DSN=MySQLServerDSN

# PostgreSQL example:
# DB_CONNECTION_STRING=dbname=mydb user=postgres password=secret host=localhost port=5432

DB_CONNECTION_STRING=

# Query Timeout (seconds)
DB_QUERY_TIMEOUT_SECONDS=30

# Data Access Permissions
# Set to 'true' to enable data access tools (db_preview, etc.)
# Default: false (requires explicit opt-in)
DB_ALLOW_DATA_ACCESS=false

# Per-tool override for db_preview
# Set to 'true' to enable db_preview without enabling all data access tools
DB_ALLOW_PREVIEW=false

# Read-Only Verification
# Set to 'true' to verify read-only status at startup (default: true)
DB_VERIFY_READONLY=true

# Fail on Write Permissions
# Set to 'true' to fail startup if write permissions are detected
# Default: false (logs warning but continues)
DB_READONLY_FAIL_ON_WRITE=false
